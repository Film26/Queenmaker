<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>QueenMaker CRM — Dashboard</title>
  <link rel="stylesheet" href="/static/styles.css">
</head>
<body class="page-dashboard">
  <div class="dashboard-shell">
    <header class="dashboard-header-top">
      <div class="brand-block">
        <img class="brand-logo-sidebar" src="/assets/369223.png" alt="QueenMaker Logo">
        <div>
          <h2>QueenMaker</h2>
          <p>Your CRM Dashboard</p>
        </div>
      </div>

      <nav class="top-menu">
        <a class="top-menu-item active" href="#">DASHBOARD</a>
        <a class="top-menu-item" href="#">CUSTOMER CRM</a>
        <a class="top-menu-item" href="#">SEGMENTATION</a>
        <a class="top-menu-item" href="#">ANALYTICS</a>
        <a class="top-menu-item" href="#">REPORTS</a>
        <a class="top-menu-item" href="#">SETTINGS</a>
      </nav>

      <div class="header-right">
        <div class="search-box">
          <span>🔍</span>
          <input type="text" placeholder="Search">
        </div>
        <a class="btn btn-secondary" href="/">Logout</a>
      </div>
    </header>

    <main class="dashboard-main">
      <section class="action-row">
        <div>
          <p class="eyebrow">DASHBOARD: CUSTOMER ANALYTICS</p>
          <h1>Overview</h1>
        </div>
        <div class="file-picker-card">
          <div class="picker-label">เลือกไฟล์ RAW</div>
          <div class="picker-row">
            <input id="fileInput" type="file" accept=".csv">
            <button id="loadSample" class="btn btn-primary">โหลดตัวอย่าง</button>
          </div>
          <div id="fileFeedback" class="file-feedback">เลือกหรือโหลดไฟล์ CSV เพื่ออัพเดตข้อมูล</div>
        </div>
      </section>

      <section class="cards-grid">
        <article class="metric-card small-card">
          <div class="metric-top">
            <span class="metric-label">TOTAL CUSTOMERS</span>
            <span class="small-badge">Total</span>
          </div>
          <h3 id="totalCustomersValue">62,032</h3>
          <p>▲ TOTAL customers</p>
          <div class="mini-chart">📈</div>
        </article>

        <article class="metric-card small-card">
          <div class="metric-top">
            <span class="metric-label">NEW CUSTOMERS</span>
            <span class="small-badge">This month</span>
          </div>
          <h3 id="newCustomersValue">754</h3>
          <p>▲ New customers</p>
          <div class="mini-chart">📈</div>
        </article>

        <article class="metric-card small-card">
          <div class="metric-top">
            <span class="metric-label">AVG SEGMENTERS</span>
            <span class="small-badge">Segment</span>
          </div>
          <h3 id="avgSegmentersValue">7.5%</h3>
          <p>Average segmenters</p>
          <div class="mini-chart">⚙️</div>
        </article>

        <article class="metric-card wide-card">
          <div class="card-row">
            <span>CUSTOMER GROWTH TRENDS (Monthly)</span>
            <button class="filter-btn">All Monthly ▾</button>
          </div>
          <div class="chart-placeholder chart-line">
            <span>Line chart</span>
          </div>
          <div class="legend-row two-col">
            <span>Line 1 (Current Year)</span>
            <span>Line 2 (Previous Year)</span>
          </div>
        </article>
      </section>

      <section class="secondary-grid">
        <article class="chart-card">
          <div class="card-row between">
            <span>CUSTOMER SEGMENTATION</span>
            <span class="badge">Filter</span>
          </div>
          <div class="chart-placeholder chart-bar">
            <span>Bar chart</span>
          </div>
          <div class="legend-row">
            <span><span class="dot dot-red"></span>Customer</span>
            <span><span class="dot dot-amber"></span>Purchase</span>
            <span><span class="dot dot-grey"></span>Others</span>
          </div>
        </article>

        <article class="chart-card metrics-stack">
          <div class="card-row between">
            <span>CRM ENGAGEMENT METRICS</span>
            <span class="badge">Filter</span>
          </div>
          <div class="metric-row">
            <div class="mini-card">
              <span>Email open rate</span>
              <h3>16.4%</h3>
              <p>▲</p>
            </div>
            <div class="mini-card">
              <span>Purchase frequency</span>
              <h3>0.00</h3>
              <p>▲</p>
            </div>
          </div>
          <div class="chart-placeholder chart-line-small">
            <span>Trend lines</span>
          </div>
        </article>
      </section>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/papaparse@5.4.1/papaparse.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <script>
    const sampleUrl = '/assets/RAW%202025%20-%20RAW.csv';
    const fileInput = document.getElementById('fileInput');
    const loadSample = document.getElementById('loadSample');
    const fileFeedback = document.getElementById('fileFeedback');
    const totalCustomers = document.getElementById('totalCustomersValue');
    const newCustomers = document.getElementById('newCustomersValue');
    const avgSegmenters = document.getElementById('avgSegmentersValue');

    function updateMetrics(rows) {
      totalCustomers.textContent = rows > 0 ? rows - 1 : 0;
      newCustomers.textContent = rows > 0 ? Math.min(754, rows - 1) : 0;
      avgSegmenters.textContent = '7.5%';
      fileFeedback.textContent = `โหลดข้อมูลเรียบร้อย: ${rows - 1} แถว`;
      fileFeedback.classList.remove('error');
    }

    function parseCsvText(text, label) {
      const results = Papa.parse(text.trim());
      if (results.data && results.data.length > 1) {
        updateMetrics(results.data.length);
      } else {
        fileFeedback.textContent = 'ไม่พบข้อมูลในไฟล์ ' + label;
        fileFeedback.classList.add('error');
      }
    }

    fileInput.addEventListener('change', (event) => {
      const file = event.target.files[0];
      if (!file) return;
      fileFeedback.textContent = `กำลังอ่านไฟล์ ${file.name} ...`;
      fileFeedback.classList.remove('error');
      Papa.parse(file, {
        complete: (results) => {
          if (results.data && results.data.length > 1) {
            updateMetrics(results.data.length);
          } else {
            fileFeedback.textContent = 'ไม่พบข้อมูลในไฟล์ ' + file.name;
            fileFeedback.classList.add('error');
          }
        },
        error: (err) => {
          fileFeedback.textContent = 'ไม่สามารถอ่านไฟล์: ' + err.message;
          fileFeedback.classList.add('error');
        }
      });
    });

    loadSample.addEventListener('click', () => {
      fetch(sampleUrl)
        .then((response) => response.text())
        .then((text) => parseCsvText(text, 'ตัวอย่าง'))
        .catch((err) => {
          fileFeedback.textContent = 'ไม่สามารถโหลดตัวอย่าง: ' + err.message;
          fileFeedback.classList.add('error');
        });
    });
  </script>
</body>
</html>






